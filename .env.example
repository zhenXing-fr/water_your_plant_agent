# Copy to `.env` and fill in. `.env` is gitignored.

# Phase 2 — required for first real LLM run
ANTHROPIC_API_KEY=sk-ant-...
OPENWEATHER_API_KEY=...

# Where the JSON garden repository reads/writes from
GARDEN_DATA_PATH=data/garden.json

# Override default model if you want
ANTHROPIC_MODEL=claude-sonnet-4-6

# Tuning knobs (optional, sensible defaults exist)
CLAUDE_MAX_TOKENS=2048
OPENWEATHER_CACHE_TTL_SECONDS=3600
